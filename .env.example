# ─── Banco de dados (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL="postgresql://peopleflow:peopleflow@localhost:5432/peopleflow?schema=public"

# ─── Redis (cache, filas, rate-limit) ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Autenticação ────────────────────────────────────────────────────────────
# Gere valores fortes: `openssl rand -base64 48`
JWT_ACCESS_SECRET="troque-este-segredo"
JWT_REFRESH_SECRET="troque-este-segredo-tambem"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ─── Criptografia de dados sensíveis (LGPD) ──────────────────────────────────
# Chave AES-256 em hex (32 bytes): `openssl rand -hex 32`
ENCRYPTION_KEY=""

# ─── Armazenamento de arquivos (Supabase Storage ou S3) ──────────────────────
STORAGE_DRIVER="supabase" # supabase | s3
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ─── IA ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
API_PORT=3001
WEB_URL="http://localhost:3000"
NODE_ENV="development"
