APP_NAME=PeopleFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

# ─── Segurança ───────────────────────────────────────────────────────────────
# Senhas com Argon2id (requisito de segurança — ver docs/ARCHITECTURE.md §7)
HASH_DRIVER=argon2id
# Access tokens Sanctum expiram em 15 minutos (refresh rotativo cuida do resto)
SANCTUM_TOKEN_EXPIRATION=15

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Banco de dados ──────────────────────────────────────────────────────────
# Desenvolvimento rápido: sqlite. Produção/paridade: PostgreSQL (docker compose up -d)
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=peopleflow
# DB_USERNAME=peopleflow
# DB_PASSWORD=peopleflow

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# ─── Redis (cache, filas/Horizon, rate limit) ────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="nao-responda@peopleflow.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage (S3 / Supabase Storage — driver s3 compatível) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=            # preencha com o endpoint do Supabase Storage, se usado
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Laravel Reverb (WebSockets) ─────────────────────────────────────────────
REVERB_APP_ID=peopleflow
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── AI Engine (config/ai.php) — OpenAI, Gemini, Claude ou Ollama ────────────
AI_PROVIDER=claude
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_URL=http://localhost:11434

VITE_APP_NAME="${APP_NAME}"
