{
  "name": "peopleflow",
  "version": "0.1.0",
  "private": true,
  "description": "PeopleFlow — Plataforma HCM (DP + RH) multi-tenant, modular e pronta para escalar.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @peopleflow/database generate",
    "db:migrate": "pnpm --filter @peopleflow/database migrate:dev",
    "db:seed": "pnpm --filter @peopleflow/database seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
