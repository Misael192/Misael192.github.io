// ═══════════════════════════════════════════════════════════════════════════
// PeopleFlow — Schema do banco de dados (fonte única de verdade)
//
// Convenções:
//  • Toda tabela de domínio carrega `tenantId` (multi-tenancy evolutiva — ADR-002).
//    RLS é habilitada por migração SQL complementar (ver migrations/rls.sql).
//  • IDs são UUID (v7 gerado na aplicação — ordenável no tempo).
//  • Soft delete via `deletedAt` em entidades de negócio; exclusão física apenas
//    pela rotina LGPD de anonimização.
//  • Campos marcados como "cifrado" armazenam AES-256-GCM aplicado na aplicação.
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, vector]
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANCY & ORGANIZAÇÃO
// ─────────────────────────────────────────────────────────────────────────────

/// Nível de isolamento do tenant (ADR-002). COLUMN é o padrão; SCHEMA/DATABASE
/// atendem clientes Enterprise sem mudança de código.
enum TenantIsolation {
  COLUMN
  SCHEMA
  DATABASE
}

model Tenant {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug           String          @unique // usado no subdomínio: <slug>.peopleflow.com.br
  name           String
  isolationLevel TenantIsolation @default(COLUMN)
  databaseUrl    String? // preenchido apenas quando isolationLevel = DATABASE (valor cifrado)
  schemaName     String? // preenchido apenas quando isolationLevel = SCHEMA
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  organizations Organization[]
  users         User[]
  subscriptions Subscription[]
  modules       TenantModule[]

  @@map("tenants")
}

model Organization {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  document  String? // CNPJ raiz (cifrado)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  companies Company[]

  @@index([tenantId])
  @@map("organizations")
}

model Company {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  organizationId String    @db.Uuid
  name           String
  tradeName      String?
  cnpj           String? // cifrado
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branches     Branch[]
  departments  Department[]
  positions    Position[]
  costCenters  CostCenter[]
  employees    Employee[]
  jobOpenings  JobOpening[]

  @@index([tenantId])
  @@map("companies")
}

model Branch {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  companyId String    @db.Uuid
  name      String
  cnpj      String? // cifrado
  address   Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]

  @@index([tenantId, companyId])
  @@map("branches")
}

model Department {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  companyId String    @db.Uuid
  parentId  String?   @db.Uuid // hierarquia de departamentos
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company      @relation(fields: [companyId], references: [id])
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  teams     Team[]
  employees Employee[]

  @@index([tenantId, companyId])
  @@map("departments")
}

model Team {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  departmentId String    @db.Uuid
  managerId    String?   @db.Uuid // Employee que gerencia o time
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department @relation(fields: [departmentId], references: [id])
  manager    Employee?  @relation("TeamManager", fields: [managerId], references: [id])
  members    Employee[] @relation("TeamMembers")

  @@index([tenantId, departmentId])
  @@map("teams")
}

model Position {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  companyId   String    @db.Uuid
  title       String
  description String? // pode ser gerada pelo AI Engine
  cboCode     String? // Classificação Brasileira de Ocupações
  salaryMin   Decimal?  @db.Decimal(12, 2)
  salaryMax   Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]

  @@index([tenantId, companyId])
  @@map("positions")
}

model CostCenter {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  companyId String    @db.Uuid
  code      String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]

  @@unique([tenantId, companyId, code])
  @@map("cost_centers")
}

// ─────────────────────────────────────────────────────────────────────────────
// IDENTITY & IAM
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  email        String
  passwordHash String? // Argon2id; null quando o usuário só entra via OAuth
  name         String
  avatarUrl    String?
  locale       String    @default("pt-BR")
  isActive     Boolean   @default(true)
  mfaEnabled   Boolean   @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  sessions        Session[]
  oauthAccounts   OAuthAccount[]
  mfaCredentials  MfaCredential[]
  roles           UserRole[]
  apiKeys         ApiKey[]
  notifications   Notification[]
  aiConversations AiConversation[]
  employee        Employee?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// Sessão = família de refresh tokens rotativos (ADR-005).
/// O token nunca é armazenado em claro; `refreshTokenHash` guarda o hash do
/// token ATUAL da família. Reuso de um token antigo revoga a sessão inteira.
model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  rotationCounter  Int       @default(0)
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("sessions")
}

model OAuthAccount {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  userId         String   @db.Uuid
  provider       String // google | microsoft | ...
  providerUserId String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([tenantId, userId])
  @@map("oauth_accounts")
}

model MfaCredential {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  userId        String    @db.Uuid
  type          String    @default("totp") // totp | webauthn (futuro)
  secret        String // cifrado
  recoveryCodes String[] // hashes dos códigos de recuperação
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("mfa_credentials")
}

/// Chave de API para integrações máquina-a-máquina. Apenas o hash é guardado;
/// o valor em claro é exibido uma única vez na criação.
model ApiKey {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  createdById String   @db.Uuid
  name       String
  keyHash    String    @unique
  prefix     String // primeiros caracteres, para identificação na UI (pf_live_ab12…)
  scopes     String[] // permissões concedidas, ex.: ["employees:read"]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}

// ─────────────────────────────────────────────────────────────────────────────
// RBAC
// ─────────────────────────────────────────────────────────────────────────────

/// Permissão atômica no formato `recurso:ação` (ex.: vacations:approve).
/// O catálogo é global (sem tenantId) e semeado por migração.
model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique // ex.: "employees:read"
  description String
  groupId     String? @db.Uuid

  group PermissionGroup? @relation(fields: [groupId], references: [id])
  roles RolePermission[]

  @@map("permissions")
}

model PermissionGroup {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String       @unique // ex.: "people", "recruitment"
  name        String
  permissions Permission[]

  @@map("permission_groups")
}

/// Papel por tenant. Papéis de sistema (isSystem) são semeados: OWNER, ADMIN,
/// HR, DP, MANAGER, EMPLOYEE — e não podem ser removidos pela UI.
model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  code      String
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, code])
  @@map("roles")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Atribuição de papel com escopo opcional (empresa/filial) — base para ABAC.
model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  companyId String?  @db.Uuid // se preenchido, papel vale só nesta empresa
  branchId  String?  @db.Uuid // idem para filial
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId, branchId])
  @@index([tenantId, userId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATAFORMA: SETTINGS, FEATURE FLAGS, MÓDULOS, INTEGRAÇÕES, NOTIFICAÇÕES
// ─────────────────────────────────────────────────────────────────────────────

/// Configuração com escopo hierárquico: plataforma → tenant → empresa → usuário.
/// A resolução usa o escopo mais específico disponível.
model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?  @db.Uuid // null = configuração de plataforma
  companyId String?  @db.Uuid
  userId    String?  @db.Uuid
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  @@unique([tenantId, companyId, userId, key])
  @@map("settings")
}

model FeatureFlag {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key               String   @unique // ex.: "recruitment.kanban-v2"
  description       String?
  enabledGlobally   Boolean  @default(false)
  rolloutPercentage Int      @default(0) // 0–100, rollout gradual
  enabledTenantIds  String[] @db.Uuid // overrides por tenant
  disabledTenantIds String[] @db.Uuid
  updatedAt         DateTime @updatedAt

  @@map("feature_flags")
}

/// Catálogo de módulos comerciais da plataforma (people, payroll, recruitment…).
model Module {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique
  name        String
  description String?
  isCore      Boolean @default(false) // módulos core não podem ser desativados

  tenants TenantModule[]

  @@map("modules")
}

/// Habilitação de módulo por tenant. `source` registra a origem (plano, trial,
/// override manual) — importante para billing e suporte.
model TenantModule {
  tenantId  String    @db.Uuid
  moduleId  String    @db.Uuid
  isEnabled Boolean   @default(true)
  source    String    @default("plan") // plan | trial | manual
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([tenantId, moduleId])
  @@map("tenant_modules")
}

model Integration {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  provider  String // slack | gupy | esocial | webhook | ...
  name      String
  config    Json // credenciais cifradas no nível do campo
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  webhookLogs WebhookLog[]

  @@index([tenantId])
  @@map("integrations")
}

model WebhookLog {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  integrationId String    @db.Uuid
  event         String
  payload       Json
  responseCode  Int?
  attempts      Int       @default(0)
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())

  integration Integration @relation(fields: [integrationId], references: [id])

  @@index([tenantId, integrationId, createdAt])
  @@map("webhook_logs")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String    @db.Uuid
  type      String // ex.: "vacation.approved"
  title     String
  body      String?
  data      Json?
  channel   String    @default("in_app") // in_app | email | push
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING (estrutura desde o MVP — ADR: plano = flags + quotas)
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String   @unique // starter | business | enterprise
  name         String
  priceCents   Int // preço mensal em centavos (BRL)
  moduleCodes  String[] // módulos incluídos
  limits       Json // { maxEmployees, maxUsers, aiTokensMonth, storageGb }
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model Subscription {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String             @db.Uuid
  planId             String             @db.Uuid
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  externalId         String? // id no gateway de pagamento (Stripe)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
  @@map("subscriptions")
}

model Invoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  subscriptionId String    @db.Uuid
  amountCents    Int
  status         String    @default("open") // open | paid | void | uncollectible
  dueDate        DateTime
  paidAt         DateTime?
  externalId     String?
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId, subscriptionId])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────────────────
// IA (AI Engine — ADR-008)
// ─────────────────────────────────────────────────────────────────────────────

model AiConversation {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String    @db.Uuid
  agent     String    @default("assistant") // agente do registry: clt, contracts, recruiter…
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User        @relation(fields: [userId], references: [id])
  messages AiMessage[]

  @@index([tenantId, userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  conversationId String   @db.Uuid
  role           String // user | assistant | tool
  content        String
  toolCalls      Json?
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  costCents      Decimal  @default(0) @db.Decimal(10, 4)
  latencyMs      Int?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId])
  @@map("ai_messages")
}

/// Prompt Library versionada — prompts curados por caso de uso (advertência,
/// contrato, descrição de cargo, comunicado…), editáveis por tenant.
model AiPromptTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?  @db.Uuid // null = template global da plataforma
  code      String // ex.: "generate-warning-letter"
  version   Int      @default(1)
  content   String
  variables String[] // variáveis esperadas, ex.: ["employeeName", "reason"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([tenantId, code, version])
  @@map("ai_prompt_templates")
}

/// Knowledge Base para RAG. `embedding` usa pgvector (dimensão do modelo de
/// embeddings configurado). Fonte: políticas do tenant, base CLT curada, etc.
model KnowledgeDocument {
  id        String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?                      @db.Uuid // null = base global (ex.: CLT)
  source    String // clt | policy | upload
  title     String
  chunk     String
  embedding Unsupported("vector(1536)")?
  metadata  Json?
  createdAt DateTime                     @default(now())

  @@index([tenantId, source])
  @@map("knowledge_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOW ENGINE (ADR-006)
// ─────────────────────────────────────────────────────────────────────────────

model WorkflowTemplate {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  name        String
  description String?
  triggerEvent String // evento que inicia o fluxo, ex.: "vacation.requested"
  version     Int       @default(1)
  definition  Json // grafo: { nodes: [...], edges: [...] } — mesmo JSON do editor visual
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  instances WorkflowInstance[]

  @@index([tenantId, triggerEvent])
  @@map("workflow_templates")
}

enum WorkflowStatus {
  RUNNING
  WAITING // aguardando ação humana (aprovação, assinatura)
  COMPLETED
  FAILED
  CANCELED
}

model WorkflowInstance {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @db.Uuid
  templateId    String         @db.Uuid
  entityType    String // ex.: "VacationRequest"
  entityId      String         @db.Uuid
  status        WorkflowStatus @default(RUNNING)
  currentNodeId String?
  context       Json // variáveis acumuladas durante a execução
  startedAt     DateTime       @default(now())
  finishedAt    DateTime?

  template WorkflowTemplate        @relation(fields: [templateId], references: [id])
  steps    WorkflowStepExecution[]

  @@index([tenantId, entityType, entityId])
  @@map("workflow_instances")
}

/// Histórico auditável de cada passo executado (Workflow History).
model WorkflowStepExecution {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  instanceId String    @db.Uuid
  nodeId     String
  nodeType   String // trigger | condition | approval | document | signature | end…
  status     String // pending | completed | rejected | failed
  actorId    String?   @db.Uuid // usuário que agiu (aprovações/assinaturas)
  input      Json?
  output     Json?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([tenantId, instanceId])
  @@map("workflow_step_executions")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDITORIA & OUTBOX DE EVENTOS
// ─────────────────────────────────────────────────────────────────────────────

/// Trilha de auditoria append-only — nunca é atualizada nem excluída
/// (constraint por trigger SQL na migração).
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  actorId    String?  @db.Uuid // null em ações de sistema
  actorType  String   @default("user") // user | api_key | system
  action     String // ex.: "employee.update"
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorId, createdAt])
  @@map("audit_logs")
}

/// Outbox do event bus (ADR-004): evento gravado na mesma transação do agregado
/// e despachado de forma assíncrona — nenhum evento se perde.
model EventOutbox {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  type        String // ex.: "vacation.approved.v1"
  payload     Json
  publishedAt DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([publishedAt, createdAt])
  @@map("event_outbox")
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULO PEOPLE / DP
// ─────────────────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ADMISSION // em processo de admissão digital
  ACTIVE
  ON_LEAVE
  VACATION
  TERMINATED
}

model Employee {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String         @db.Uuid
  companyId    String         @db.Uuid
  branchId     String?        @db.Uuid
  departmentId String?        @db.Uuid
  teamId       String?        @db.Uuid
  positionId   String?        @db.Uuid
  costCenterId String?        @db.Uuid
  userId       String?        @unique @db.Uuid // vínculo com login do portal do colaborador
  managerId    String?        @db.Uuid

  registrationNumber String // matrícula
  fullName           String
  socialName         String?
  cpf                String? // cifrado
  rg                 String? // cifrado
  birthDate          DateTime?
  phone              String?
  personalEmail      String?
  address            Json?
  bankInfo           Json? // cifrado
  status             EmployeeStatus @default(ADMISSION)
  hiredAt            DateTime?
  terminatedAt       DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  company     Company      @relation(fields: [companyId], references: [id])
  branch      Branch?      @relation(fields: [branchId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])
  team        Team?        @relation("TeamMembers", fields: [teamId], references: [id])
  position    Position?    @relation(fields: [positionId], references: [id])
  costCenter  CostCenter?  @relation(fields: [costCenterId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  manager     Employee?    @relation("ManagerReports", fields: [managerId], references: [id])
  reports     Employee[]   @relation("ManagerReports")
  managedTeams Team[]      @relation("TeamManager")

  contracts        EmploymentContract[]
  timeEntries      TimeEntry[]
  timeBankEntries  TimeBankEntry[]
  vacationRequests VacationRequest[]
  documents        Document[]
  payslips         Payslip[]
  benefits         EmployeeBenefit[]
  goals            Goal[]
  reviews          PerformanceReview[]
  enrollments      TrainingEnrollment[]
  recognitions     Recognition[]        @relation("RecognitionReceived")

  @@unique([tenantId, companyId, registrationNumber])
  @@index([tenantId, companyId, status])
  @@map("employees")
}

model EmploymentContract {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  employeeId   String    @db.Uuid
  type         String // clt | pj | estagio | temporario
  salaryCents  Int?
  weeklyHours  Int?
  startDate    DateTime
  endDate      DateTime?
  documentId   String?   @db.Uuid // contrato assinado no GED
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
  @@map("employment_contracts")
}

/// Escala de trabalho (ex.: 5x2 08:00–17:00, 12x36). `rules` guarda a definição
/// flexível de dias/horários usada no cálculo de jornada e banco de horas.
model WorkSchedule {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  companyId String   @db.Uuid
  name      String
  rules     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeEntries TimeEntry[]

  @@index([tenantId, companyId])
  @@map("work_schedules")
}

enum TimeEntryStatus {
  RECORDED
  ADJUSTMENT_REQUESTED
  APPROVED
  REJECTED
}

/// Registro de ponto. Idempotency key evita duplicidade em reenvio mobile.
model TimeEntry {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String          @db.Uuid
  employeeId     String          @db.Uuid
  scheduleId     String?         @db.Uuid
  type           String // clock_in | clock_out | break_start | break_end
  recordedAt     DateTime
  source         String          @default("web") // web | mobile
  latitude       Decimal?        @db.Decimal(9, 6)
  longitude      Decimal?        @db.Decimal(9, 6)
  status         TimeEntryStatus @default(RECORDED)
  adjustReason   String? // preenchido em pedidos de ajuste
  approvedById   String?         @db.Uuid
  idempotencyKey String?         @unique
  createdAt      DateTime        @default(now())

  employee Employee      @relation(fields: [employeeId], references: [id])
  schedule WorkSchedule? @relation(fields: [scheduleId], references: [id])

  @@index([tenantId, employeeId, recordedAt])
  @@map("time_entries")
}

/// Lançamento no banco de horas (positivo = crédito, negativo = débito, em minutos).
model TimeBankEntry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  employeeId String   @db.Uuid
  minutes    Int
  reason     String // overtime | compensation | adjustment
  referenceDate DateTime @db.Date
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, referenceDate])
  @@map("time_bank_entries")
}

enum VacationStatus {
  REQUESTED
  APPROVED
  REJECTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model VacationRequest {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String         @db.Uuid
  employeeId   String         @db.Uuid
  startDate    DateTime       @db.Date
  endDate      DateTime       @db.Date
  days         Int
  sellDays     Int            @default(0) // abono pecuniário
  status       VacationStatus @default(REQUESTED)
  approvedById String?        @db.Uuid
  decidedAt    DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, status])
  @@map("vacation_requests")
}

// ─── GED (Gestão Eletrônica de Documentos) ──────────────────────────────────

model Document {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  employeeId String?   @db.Uuid // documento pode pertencer a um colaborador ou à empresa
  category   String // contract | admission | medical | policy | payslip | other
  name       String
  createdById String?  @db.Uuid
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  employee  Employee?          @relation(fields: [employeeId], references: [id])
  versions  DocumentVersion[]
  signatures SignatureRequest[]

  @@index([tenantId, employeeId, category])
  @@map("documents")
}

/// Controle de versões: cada upload gera uma versão imutável no storage.
model DocumentVersion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  documentId  String   @db.Uuid
  version     Int
  storageKey  String // caminho no Supabase Storage / S3
  mimeType    String
  sizeBytes   Int
  checksum    String // SHA-256 — integridade e deduplicação
  uploadedById String? @db.Uuid
  createdAt   DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@map("document_versions")
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
}

model SignatureRequest {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String          @db.Uuid
  documentId String          @db.Uuid
  signerId   String          @db.Uuid // User
  status     SignatureStatus @default(PENDING)
  signedAt   DateTime?
  signatureHash String? // hash do documento + evidências no momento da assinatura
  evidence   Json? // IP, user agent, geolocalização, timestamp confiável
  expiresAt  DateTime?
  createdAt  DateTime        @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([tenantId, signerId, status])
  @@map("signature_requests")
}

/// Holerite — o PDF fica no GED; aqui ficam competência e metadados.
model Payslip {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  employeeId    String    @db.Uuid
  competency    String // "2026-07"
  grossCents    Int?
  netCents      Int?
  documentId    String?   @db.Uuid
  publishedAt   DateTime?
  viewedAt      DateTime?
  createdAt     DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, competency])
  @@map("payslips")
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULO RECRUITMENT
// ─────────────────────────────────────────────────────────────────────────────

enum JobOpeningStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
}

model JobOpening {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @db.Uuid
  companyId   String           @db.Uuid
  title       String
  description String
  location    String?
  isRemote    Boolean          @default(false)
  isPublished Boolean          @default(false) // aparece na página Trabalhe Conosco
  status      JobOpeningStatus @default(DRAFT)
  pipeline    Json // colunas do Kanban, ex.: ["Triagem","Entrevista","Proposta"]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  company      Company          @relation(fields: [companyId], references: [id])
  applications JobApplication[]

  @@index([tenantId, companyId, status])
  @@map("job_openings")
}

model Candidate {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  fullName   String
  email      String
  phone      String?
  resumeKey  String? // currículo no storage
  resumeSummary String? // resumo gerado pelo AI Engine
  linkedinUrl String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? // LGPD: candidatos podem pedir exclusão

  applications JobApplication[]

  @@unique([tenantId, email])
  @@map("candidates")
}

model JobApplication {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  jobOpeningId String   @db.Uuid
  candidateId  String   @db.Uuid
  stage        String // coluna atual do Kanban
  score        Int? // avaliação consolidada
  history      Json // trilha do processo seletivo: [{stage, at, by, notes}]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobOpening JobOpening  @relation(fields: [jobOpeningId], references: [id])
  candidate  Candidate   @relation(fields: [candidateId], references: [id])
  interviews Interview[]

  @@unique([jobOpeningId, candidateId])
  @@index([tenantId, jobOpeningId, stage])
  @@map("job_applications")
}

model Interview {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  applicationId String    @db.Uuid
  interviewerId String    @db.Uuid // User
  scheduledAt   DateTime
  location      String? // presencial ou link de vídeo
  feedback      String?
  score         Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id])

  @@index([tenantId, applicationId])
  @@map("interviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULO BENEFITS
// ─────────────────────────────────────────────────────────────────────────────

model Benefit {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  type        String // vt | va | vr | health | dental | other
  name        String
  provider    String? // convênio/operadora
  costCents   Int?
  config      Json? // regras específicas (percentual de desconto etc.)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  employees EmployeeBenefit[]

  @@index([tenantId, type])
  @@map("benefits")
}

model EmployeeBenefit {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  employeeId String    @db.Uuid
  benefitId  String    @db.Uuid
  startDate  DateTime  @db.Date
  endDate    DateTime? @db.Date
  usage      Json? // controle de utilização
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  benefit  Benefit  @relation(fields: [benefitId], references: [id])

  @@unique([employeeId, benefitId, startDate])
  @@index([tenantId, employeeId])
  @@map("employee_benefits")
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULOS PERFORMANCE & LEARNING
// ─────────────────────────────────────────────────────────────────────────────

model Goal {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  employeeId String    @db.Uuid
  title      String
  description String?
  metric     String? // como a meta é medida
  target     Decimal?  @db.Decimal(12, 2)
  progress   Decimal   @default(0) @db.Decimal(5, 2) // 0–100%
  dueDate    DateTime? @db.Date
  status     String    @default("active") // active | achieved | missed | canceled
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, status])
  @@map("goals")
}

model PerformanceReview {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  employeeId  String   @db.Uuid
  reviewerId  String   @db.Uuid // User
  cycle       String // "2026-S1"
  type        String   @default("manager") // manager | self | 360 | behavioral
  competencies Json // [{name, score, comment}]
  overallScore Decimal? @db.Decimal(4, 2)
  feedback    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, cycle])
  @@map("performance_reviews")
}

model Training {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  title       String
  description String?
  contentUrl  String? // vídeo/material no storage
  durationMin Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  enrollments TrainingEnrollment[]

  @@index([tenantId])
  @@map("trainings")
}

model TrainingEnrollment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  trainingId     String    @db.Uuid
  employeeId     String    @db.Uuid
  progress       Decimal   @default(0) @db.Decimal(5, 2)
  completedAt    DateTime?
  certificateKey String? // certificado gerado, no storage
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  training Training @relation(fields: [trainingId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([trainingId, employeeId])
  @@index([tenantId, employeeId])
  @@map("training_enrollments")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENGAJAMENTO & COMUNICAÇÃO
// ─────────────────────────────────────────────────────────────────────────────

model Survey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  type        String // climate | satisfaction | enps
  title       String
  questions   Json // [{id, text, type, options}]
  isAnonymous Boolean   @default(true) // pesquisas de clima são anônimas por padrão
  opensAt     DateTime?
  closesAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  responses SurveyResponse[]

  @@index([tenantId, type])
  @@map("surveys")
}

model SurveyResponse {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  surveyId   String   @db.Uuid
  employeeId String?  @db.Uuid // null quando a pesquisa é anônima
  answers    Json
  createdAt  DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id])

  @@index([tenantId, surveyId])
  @@map("survey_responses")
}

/// Mural de avisos / comunicação interna.
model Announcement {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  companyId   String?   @db.Uuid // null = todas as empresas do tenant
  authorId    String    @db.Uuid
  title       String
  body        String
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, companyId, publishedAt])
  @@map("announcements")
}

/// Reconhecimento entre colaboradores.
model Recognition {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  fromUserId   String   @db.Uuid
  toEmployeeId String   @db.Uuid
  message      String
  badge        String? // ex.: "team-player", "above-and-beyond"
  createdAt    DateTime @default(now())

  toEmployee Employee @relation("RecognitionReceived", fields: [toEmployeeId], references: [id])

  @@index([tenantId, toEmployeeId])
  @@map("recognitions")
}
